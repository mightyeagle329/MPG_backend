# Canva Connect API credentials (get these from canva.com/developers)
CANVA_CLIENT_ID=your_client_id_here
CANVA_CLIENT_SECRET=your_client_secret_here
CANVA_REDIRECT_URI=http://127.0.0.1:7000/oauth/callback

# Brand Template IDs per incentive tier
CANVA_TEMPLATE_5K=EAHKUb8jzyc
CANVA_TEMPLATE_10K=EAHKUUeTJOA

# Local storage for tokens (development only)
TOKEN_FILE=./.canva_token.json

# Server
HOST=127.0.0.1
PORT=7000
